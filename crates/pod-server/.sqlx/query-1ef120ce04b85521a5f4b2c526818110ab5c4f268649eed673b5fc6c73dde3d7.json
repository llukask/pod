{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT u.id, u.username, u.password_hash, u.created_at, u.last_updated\n            FROM users u\n            JOIN sessions s ON u.id = s.user_id\n            WHERE s.session_id = $1 AND s.expires_at > current_timestamp\n            ",
